{
  "name": "@agentic-payment/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@agentic-payment/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.1",
    "bullmq": "^5.41.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.6.0",
    "pg": "^8.13.3",
    "stripe": "^17.6.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.8"
  }
}